# Copy to .env and fill in. NEVER commit .env. Secrets are injected at runtime
# (control plane only) and must never reach the execution-plane container.

# --- Core ---
APP_ENV=local                       # local | ci | prod
LOG_LEVEL=INFO

# --- Workspace (where repos are cloned) ---
WORKSPACE_ROOT=./workspaces

# --- Anthropic (Phase 3+) ---
ANTHROPIC_API_KEY=                   # provided at runtime, never committed
AGENT_MODEL=claude-opus-4-8
AGENT_LOCALIZER_MODEL=claude-haiku-4-5-20251001

# --- Postgres + pgvector (Phase 1 fallback retrieval, Phase 6+) ---
# psycopg3 serves both sync (Alembic) and async (app) from this one URL.
DATABASE_URL=postgresql+psycopg://bugfix:bugfix@localhost:5432/bugfix
DB_ECHO=false                        # SQL echo for debugging

# --- API / webhook (Phase 6+) ---
API_HOST=0.0.0.0
API_PORT=8000
AUTOFIX_LABEL=autofix                # issue label that enqueues a fix job

# --- Redis / arq (Phase 7+) ---
REDIS_URL=redis://localhost:6379/0

# --- GitHub App (Phase 5+) ---
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=              # PEM; runtime secret
GITHUB_WEBHOOK_SECRET=

# --- Dev bootstrap / scrape (Phase 14, dev-only) ---
SCRAPE_ON_START=true                 # let `npm run dev` run the wipe+scrape bootstrap
SCRAPE_LABEL=autofix                 # open issues to pull (empty / --all-issues = all)
SCRAPE_MAX_JOBS=10                   # safety cap on jobs a scrape enqueues
SCRAPE_REPOS=owner/repo              # comma-separated installed repos to scrape

# --- Langfuse (Phase 10+) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

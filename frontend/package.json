{
  "name": "bugfix-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev:web": "vite",
    "dev:infra": "docker compose -f ../docker-compose.yml up -d postgres redis",
    "dev:migrate": "cd .. && uv run alembic upgrade head",
    "dev:bootstrap": "cd .. && uv run bugfix-bootstrap --reset",
    "predev": "npm run dev:infra && wait-on tcp:127.0.0.1:5432 tcp:127.0.0.1:6379 && npm run dev:migrate && npm run dev:bootstrap",
    "dev": "concurrently -k -n api,worker,web -c green,yellow,cyan \"cd .. && uv run bugfix-api\" \"cd .. && uv run bugfix-worker\" \"vite\"",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.0.1",
    "wait-on": "^8.0.1",
    "jsdom": "^24.1.0",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "vite": "^5.3.3",
    "vitest": "^2.0.2"
  }
}
